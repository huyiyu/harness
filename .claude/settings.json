{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "defaultMode": "default",
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Bash(docker *)",
      "Bash(cd *)",
      "Bash(curl *)",
      "Bash(ls)",
      "Bash(ls *)",
      "Bash(pwd)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(grep *)",
      "Bash(rg *)",
      "Bash(find *)",
      "Bash(wc *)",
      "Bash(file *)",
      "Bash(stat *)",
      "Bash(which *)",
      "Bash(whereis *)",
      "Bash(type *)",
      "Bash(whoami)",
      "Bash(id)",
      "Bash(id *)",
      "Bash(hostname)",
      "Bash(uname *)",
      "Bash(date)",
      "Bash(date *)",
      "Bash(tree)",
      "Bash(tree *)",
      "Bash(du *)",
      "Bash(df *)",
      "Bash(free *)",
      "Bash(env)",
      "Bash(printenv *)",
      "Bash(echo *)",
      "Bash(ps)",
      "Bash(ps *)",
      "Bash(node -v)",
      "Bash(node --version)",
      "Bash(python --version)",
      "Bash(python3 --version)",
      "Bash(go version)",
      "Bash(npm list*)",
      "Bash(npm ls*)",
      "Bash(yarn list*)",
      "Bash(pnpm list*)",
      "Bash(git status*)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(git show*)",
      "Bash(git branch*)",
      "Bash(git remote*)",
      "Bash(git ls-files*)",
      "Bash(git rev-parse*)",
      "Bash(git describe*)",
      "Bash(git stash list*)",
      "Bash(git tag)",
      "Bash(git tag -l*)",
      "Bash(git config --list*)",
      "Bash(git config --get*)",
      "Bash(git blame*)",
      "Bash(git reflog*)",
      "Bash(git shortlog*)"
    ],
    "ask": [
      "Bash(rm *)",
      "Bash(sudo *)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git push origin --force*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -f*)",
      "Bash(git clean -d*)",
      "Bash(git clean -x*)",
      "Bash(git checkout -- *)",
      "Write(/etc/*)",
      "Write(/usr/*)",
      "Write(/var/*)",
      "Write(/opt/*)",
      "Write(/bin/*)",
      "Write(/sbin/*)",
      "Edit(/etc/*)",
      "Edit(/usr/*)",
      "Edit(/var/*)",
      "Edit(/opt/*)",
      "Edit(/bin/*)",
      "Edit(/sbin/*)",
      "Write(/home/huyiyu/.ssh/*)",
      "Write(/home/huyiyu/.aws/*)",
      "Write(/home/huyiyu/.gnupg/*)",
      "Edit(/home/huyiyu/.ssh/*)",
      "Edit(/home/huyiyu/.aws/*)",
      "Edit(/home/huyiyu/.gnupg/*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/git-write-check.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/bash-sensitive-check.sh"
          }
        ]
      }
    ]
  }
}
